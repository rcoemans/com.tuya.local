{
  "id": "dp_value_is",
  "title": {
    "en": "Datapoint value !{{is|is not}} equal to",
    "nl": "Datapuntwaarde !{{is|is niet}} gelijk aan"
  },
  "titleFormatted": {
    "en": "Datapoint [[dp]] !{{is|is not}} [[value]]",
    "nl": "Datapunt [[dp]] !{{is|is niet}} [[value]]"
  },
  "hint": {
    "en": "Checks if a specific Tuya datapoint has a given value.",
    "nl": "Controleert of een specifiek Tuya-datapunt een bepaalde waarde heeft."

  "brandColor": "#00A6A6",
  "name": {
    "en": "Tuya Direct",
    "nl": "Tuya Direct"
  },
  "description": {
    "en": "Adds local LAN control for compatible Tuya-based devices on Homey Pro. Connect devices directly over your local network using their device ID, local key and datapoints for faster status updates and cloud-independent control.",
    "nl": "Voegt lokale LAN-besturing toe voor compatibele Tuya-apparaten op Homey Pro. Verbind apparaten rechtstreeks via je lokale netwerk met hun apparaat-ID, lokale sleutel en datapunten voor snellere statusupdates en cloudloze besturing."
  },
  "category": [
    "tools"
  ],
  "permissions": [],
  "tags": {
    "en": ["tuya", "local", "lan", "wifi", "smart life", "smart plug", "smart light"],
    "nl": ["tuya", "lokaal", "lan", "wifi", "smart life", "slimme stekker", "slim licht"]
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Robert Coemans",
    "email": "r.coemans@hotmail.com"
  },
  "homepage": "https://github.com/rcoemans/com.tuya.local",
  "support": "https://github.com/rcoemans/com.tuya.local/issues",
  "source": "https://github.com/rcoemans/com.tuya.local",
  "bugs": {
    "url": "https://github.com/rcoemans/com.tuya.local/issues"
  },
  "flow": {
    "triggers": [
      {
        "id": "device_connected",
        "title": { "en": "Device connected", "nl": "Apparaat verbonden" },
        "hint": { "en": "Triggers when the Tuya device establishes a local connection.", "nl": "Wordt geactiveerd wanneer het Tuya-apparaat een lokale verbinding tot stand brengt." },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=socket|light|fan|climate" }]
      },
      {
        "id": "device_disconnected",
        "title": { "en": "Device disconnected", "nl": "Apparaat losgekoppeld" },
        "hint": { "en": "Triggers when the Tuya device loses its local connection.", "nl": "Wordt geactiveerd wanneer het Tuya-apparaat de lokale verbinding verliest." },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=socket|light|fan|climate" }]
      },
      {
        "id": "dp_changed",
        "title": { "en": "A datapoint changed", "nl": "Een datapunt is gewijzigd" },
        "titleFormatted": { "en": "Datapoint [[dp]] changed", "nl": "Datapunt [[dp]] is gewijzigd" },
        "hint": { "en": "Triggers when a specific Tuya datapoint value changes.", "nl": "Wordt geactiveerd wanneer een specifiek Tuya-datapuntwaarde verandert." },
        "args": [
          { "type": "device", "name": "device", "filter": "driver_id=socket|light|fan|climate" },
          { "type": "text", "name": "dp", "title": { "en": "Datapoint", "nl": "Datapunt" }, "placeholder": { "en": "e.g. 1", "nl": "bijv. 1" } }
        ],
        "tokens": [
          { "name": "value", "type": "string", "title": { "en": "Value", "nl": "Waarde" }, "example": { "en": "true", "nl": "true" } },
          { "name": "dp", "type": "string", "title": { "en": "Datapoint", "nl": "Datapunt" }, "example": { "en": "1", "nl": "1" } }
        ]
      }
    ],
    "conditions": [
      {
        "id": "device_is_connected",
        "title": { "en": "Device !{{is|is not}} connected", "nl": "Apparaat !{{is|is niet}} verbonden" },
        "hint": { "en": "Checks if the Tuya device currently has an active local connection.", "nl": "Controleert of het Tuya-apparaat momenteel een actieve lokale verbinding heeft." },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=socket|light|fan|climate" }]
      },
      {
        "id": "dp_value_is",
        "title": { "en": "Datapoint value !{{is|is not}} equal to", "nl": "Datapuntwaarde !{{is|is niet}} gelijk aan" },
        "titleFormatted": { "en": "Datapoint [[dp]] !{{is|is not}} [[value]]", "nl": "Datapunt [[dp]] !{{is|is niet}} [[value]]" },
        "hint": { "en": "Checks if a specific Tuya datapoint has a given value.", "nl": "Controleert of een specifiek Tuya-datapunt een bepaalde waarde heeft." },
        "args": [
          { "type": "device", "name": "device", "filter": "driver_id=socket|light|fan|climate" },
          { "type": "text", "name": "dp", "title": { "en": "Datapoint", "nl": "Datapunt" }, "placeholder": { "en": "e.g. 1", "nl": "bijv. 1" } },
          { "type": "text", "name": "value", "title": { "en": "Value", "nl": "Waarde" }, "placeholder": { "en": "e.g. true", "nl": "bijv. true" } }
        ]
      }
    ],
    "actions": [
      {
        "id": "set_dp",
        "title": { "en": "Set datapoint value", "nl": "Stel datapuntwaarde in" },
        "titleFormatted": { "en": "Set datapoint [[dp]] to [[value]]", "nl": "Stel datapunt [[dp]] in op [[value]]" },
        "hint": { "en": "Set a specific Tuya datapoint to a value. For boolean use 'true' or 'false', for numbers use a numeric value.", "nl": "Stel een specifiek Tuya-datapunt in op een waarde. Gebruik voor boolean 'true' of 'false', voor getallen een numerieke waarde." },
        "args": [
          { "type": "device", "name": "device", "filter": "driver_id=socket|light|fan|climate" },
          { "type": "text", "name": "dp", "title": { "en": "Datapoint", "nl": "Datapunt" }, "placeholder": { "en": "e.g. 1", "nl": "bijv. 1" } },
          { "type": "text", "name": "value", "title": { "en": "Value", "nl": "Waarde" }, "placeholder": { "en": "e.g. true", "nl": "bijv. true" } }
        ]
      },
      {
        "id": "refresh_status",
        "title": { "en": "Refresh device status", "nl": "Ververs apparaatstatus" },
        "hint": { "en": "Request a fresh status update from the Tuya device.", "nl": "Vraag een nieuwe statusupdate op van het Tuya-apparaat." },
        "args": [{ "type": "device", "name": "device", "filter": "driver_id=socket|light|fan|climate" }]
      }
    ]
  },
  "drivers": [
